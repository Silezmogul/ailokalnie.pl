# Ignore everything by default
*

# Allow website (only tracked content)
!index.html
!static/
!static/**
!hero.png
!CNAME
!.github/
!.github/**

# Allow in-repo inspiration reference (parity spec)
!Inspirations/
!Inspirations/ailokalnie.pl-website/
!Inspirations/ailokalnie.pl-website/**

# Do not track large third-party demo assets; keep just the minimal local spec
Inspirations/ailokalnie.pl-website/Inspirations/
Inspirations/ailokalnie.pl-website/Notes/
Inspirations/ailokalnie.pl-website/backup/

# Keep .gitignore itself tracked
!.gitignore

# Do not ignore directories so git can traverse for un-ignores
!*/
